{
  "name": "@pyramid-os/cli",
  "version": "0.1.0",
  "description": "Command-line interface for PYRAMID OS administration",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pyramid-os": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pyramid-os/shared-types": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^4.6.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
