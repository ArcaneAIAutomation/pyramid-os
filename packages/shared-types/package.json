{
  "name": "@pyramid-os/shared-types",
  "version": "0.1.0",
  "description": "Shared TypeScript types for PYRAMID OS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "fast-check": "^3.22.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
