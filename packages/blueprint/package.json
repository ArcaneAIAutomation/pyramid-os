{
  "name": "@pyramid-os/blueprint",
  "version": "0.1.0",
  "description": "Blueprint system for PYRAMID OS — structure definitions, serialization, and validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@pyramid-os/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^3.23.2",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
